# Copy this file to .env and fill values
# Google Maps API key (enable Maps JavaScript API + Places)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Email (Gmail) credentials for sending alerts (optional)
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_gmail_app_password_or_oauth_token

# Optional: Twilio credentials for SMS alerts
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_FROM=+1234567890

# Optional admin email to notify on severe PHQ results
SOS_EMAIL_TO=admin@yourorg.com

# MySQL (optional)
MYSQL_HOST=127.0.0.1
MYSQL_USER=root
MYSQL_PASSWORD=
